#!/bin/bash
set -euo pipefail

VM_NAME="${1:-tools-vm}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VM_CONFIG="$SCRIPT_DIR/tools-vm.yaml"
LOG_FILE="/tmp/rebuild-tools-vm-$$.log"

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

step() { echo -e "${GREEN}==> $1${NC}"; }
warn() { echo -e "${YELLOW}    $1${NC}"; }
fail() { echo -e "${RED}==> ERROR: $1${NC}"; }

if [ ! -f "$VM_CONFIG" ]; then
  fail "$VM_CONFIG not found"
  exit 1
fi

echo "Log file: $LOG_FILE"
echo

# Check if VM exists and tear it down
if limactl list -q 2>/dev/null | grep -q "^${VM_NAME}$"; then
  step "Removing existing VM '$VM_NAME'..."
  limactl stop "$VM_NAME" 2>/dev/null || true
  limactl delete -f "$VM_NAME" >> "$LOG_FILE" 2>&1
fi

step "Creating VM '$VM_NAME' (downloading Ubuntu image if needed)..."
warn "This may take several minutes on first run."
limactl create --name="$VM_NAME" "$VM_CONFIG" -y >> "$LOG_FILE" 2>&1

step "Starting VM and running provisioning..."
warn "Installing: build tools, Go, Rust, Node.js, Python/uv, Docker, JVM tools, Claude Code"
warn "This typically takes 5-10 minutes. Tail the log for details:"
warn "  tail -f $LOG_FILE"
limactl start "$VM_NAME" >> "$LOG_FILE" 2>&1

step "Verifying tools installation..."
fail_count=0
check() {
  if limactl shell "$VM_NAME" bash -lc "command -v $1" > /dev/null 2>&1; then
    echo -e "  ${GREEN}✓${NC} $1"
  else
    echo -e "  ${RED}✗${NC} $1"
    fail_count=$((fail_count + 1))
  fi
}

check claude
check node
check npm
check rustc
check cargo
check go
check python3
check uv
check docker
check java
check kotlin
check gradle
check mvn

if [ $fail_count -ne 0 ]; then
  fail "$fail_count tool(s) failed to install. Check the log:"
  echo "  $LOG_FILE"
  echo "  limactl shell $VM_NAME"
  exit 1
fi

step "VM '$VM_NAME' is ready!"
echo "  ./claude-sandbox --clone-from $VM_NAME"
